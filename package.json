{
  "name": "codewhisper",
  "version": "1.0.0",
  "description": "AI-powered coding assistant desktop app",
  "main": "main/index.js",
  "scripts": {
    "start": "concurrently -k -n REACT,ELECTRON -c cyan,yellow \"npm run react\" \"npm run electron:wait\"",
    "react": "npm start --prefix renderer",
    "electron:wait": "wait-on tcp:3000 && cross-env NODE_ENV=development electron .",
    "electron": "cross-env NODE_ENV=development electron .",
    "build": "npm run build --prefix renderer && electron-builder",
    "build:win": "npm run build --prefix renderer && electron-builder --win",
    "build:mac": "npm run build --prefix renderer && electron-builder --mac",
    "build:linux": "npm run build --prefix renderer && electron-builder --linux"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.codewhisper.app",
    "productName": "CodeWhisper",
    "copyright": "Copyright © 2024 CodeWhisper",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main/**/*",
      "renderer/build/**/*",
      "!**/node_modules/**",
      "!renderer/src/**",
      "!renderer/public/**"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CodeWhisper"
    },
    "dmg": {
      "title": "CodeWhisper",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  }
}
